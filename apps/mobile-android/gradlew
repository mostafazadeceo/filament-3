#!/usr/bin/env sh

set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
JAVA_EXEC="${JAVA_HOME:+$JAVA_HOME/bin/}java"
WRAPPER_JAR="$DIR/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_SHARED="$DIR/gradle/wrapper/gradle-wrapper-shared.jar"

exec "$JAVA_EXEC" -classpath "$WRAPPER_JAR:$WRAPPER_SHARED" org.gradle.wrapper.GradleWrapperMain "$@"
