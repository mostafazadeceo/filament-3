{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ariaieboy/filament-jalali": "^2.1",
        "barryvdh/laravel-dompdf": "*",
        "diogogpinto/filament-auth-ui-enhancer": "^2.0",
        "filamat/filamat-iam-suite": "dev-main",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-settings-plugin": "^4.3",
        "geniusts/hijri-dates": "^1.2",
        "haida/filament-currency-rates": "^1.0",
        "haida/filament-notify-bale": "^1.0",
        "haida/filament-notify-core": "^1.0",
        "haida/filament-notify-sms-ippanel": "^1.0",
        "haida/filament-notify-telegram": "^1.0",
        "haida/filament-notify-webpush": "^1.0",
        "haida/filament-notify-whatsapp": "^1.0",
        "haida/filament-relograde": "^1.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "mohamedsabil83/filament-hijri-picker": "^2.1",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-settings": "^3.6",
        "zpmlabs/filament-api-docs-builder": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/filament-notify-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-notify-sms-ippanel",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-notify-telegram",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-notify-whatsapp",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-notify-bale",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-notify-webpush",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-relograde",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filament-currency-rates",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/filamat-iam-suite",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
