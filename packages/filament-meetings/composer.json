{
    "name": "haida/filament-meetings",
    "version": "1.0.0",
    "description": "Meetings module with AI-assisted agenda and minutes for Filament v4.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "haida/filament-ai-core": "*",
        "haida/filament-workhub": "*"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentMeetings\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentMeetings\\FilamentMeetingsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
