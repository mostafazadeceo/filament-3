{
    "name": "haida/site-builder-core",
    "version": "1.0.0",
    "description": "Core site builder domain models and Filament plugin.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\SiteBuilderCore\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\SiteBuilderCore\\SiteBuilderCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
