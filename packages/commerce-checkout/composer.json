{
    "name": "haida/commerce-checkout",
    "version": "1.0.0",
    "type": "library",
    "description": "Commerce cart and checkout flows for Haida platform.",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Haida\\CommerceCheckout\\": "src/"
        }
