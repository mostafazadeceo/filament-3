{
    "name": "haida/filament-notify-sms-ippanel",
    "version": "1.0.0",
    "description": "IPPanel Pattern SMS channel for Filament Notify.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "haida/filament-notify-core": "*",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentNotify\\SmsIppanel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentNotify\\SmsIppanel\\FilamentNotifySmsIppanelServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
