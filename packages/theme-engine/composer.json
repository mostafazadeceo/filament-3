{
    "name": "haida/theme-engine",
    "version": "1.0.0",
    "description": "Theme registry and relograde-v1 assets for Site OS.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\ThemeEngine\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\ThemeEngine\\ThemeEngineServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
