{
    "name": "haida/feature-gates",
    "version": "1.0.0",
    "description": "Central feature gate system for plan and tenant entitlements.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FeatureGates\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FeatureGates\\FeatureGatesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
