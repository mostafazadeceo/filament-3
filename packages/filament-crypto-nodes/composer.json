{
    "name": "haida/filament-crypto-nodes",
    "version": "0.1.0",
    "description": "Self-hosted crypto node connectors and BTCPay fallback.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "haida/filament-crypto-core": "^0.1.0",
        "haida/filament-crypto-gateway": "^0.1.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentCryptoNodes\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentCryptoNodes\\FilamentCryptoNodesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
