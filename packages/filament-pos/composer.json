{
    "name": "haida/filament-pos",
    "version": "1.0.0",
    "description": "POS core and offline sync for Hub.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentPos\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentPos\\FilamentPosServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
