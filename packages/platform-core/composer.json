{
    "name": "haida/platform-core",
    "version": "1.0.0",
    "description": "Platform core kernel for plugin registry and lifecycle.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\PlatformCore\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\PlatformCore\\PlatformCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
