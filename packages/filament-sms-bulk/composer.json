{
    "name": "haida/filament-sms-bulk",
    "version": "1.0.0",
    "description": "Bulk SMS + reseller platform module for Filament v4 multi-tenant SaaS.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "filament/filament": "^4.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/support": "^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\SmsBulk\\": "src/",
            "Haida\\SmsBulk\\Database\\Factories\\": "database/factories/",
            "Haida\\SmsBulk\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\SmsBulk\\FilamentSmsBulkServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
