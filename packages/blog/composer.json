{
    "name": "haida/blog",
    "version": "1.0.0",
    "description": "Blog module for Site OS.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "haida/page-builder": "^1.0",
        "haida/site-builder-core": "^1.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\Blog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
