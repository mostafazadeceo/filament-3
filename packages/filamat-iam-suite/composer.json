{
    "name": "filamat/filamat-iam-suite",
    "description": "Filamat 4 IAM Suite for Filament v4",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.28 || ^12.0",
        "laravel/sanctum": "^4.0",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "nunomaduro/collision": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Filamat\\IamSuite\\": "src/",
            "Filamat\\IamSuite\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Filamat\\IamSuite\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Filamat\\IamSuite\\FilamatIamSuiteServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
