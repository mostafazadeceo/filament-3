{
    "name": "haida/filament-payroll-attendance",
    "version": "1.0.0",
    "description": "Payroll and attendance module for Iran (Filament v4).",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentPayrollAttendance\\": "src/",
            "Haida\\FilamentPayrollAttendance\\Database\\Factories\\": "database/factories/",
            "Haida\\FilamentPayrollAttendance\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentPayrollAttendance\\FilamentPayrollAttendanceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
