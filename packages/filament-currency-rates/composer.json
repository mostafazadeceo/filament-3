{
    "name": "haida/filament-currency-rates",
    "version": "1.0.0",
    "description": "افزونه فیلامنت برای همگام‌سازی و ارائه نرخ ارز به ریال ایران.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0|^4.0",
        "illuminate/bus": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-settings": "^3.6"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentCurrencyRates\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Haida\\FilamentCurrencyRates\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentCurrencyRates\\CurrencyRatesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
