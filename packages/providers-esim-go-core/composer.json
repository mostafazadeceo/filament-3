{
    "name": "haida/providers-esim-go-core",
    "version": "1.0.0",
    "description": "Core integration for eSIM Go provider (client, models, services).",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filamat/filamat-iam-suite": "dev-main",
        "haida/filament-notify-core": "^1.0",
        "haida/providers-core": "^1.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\ProvidersEsimGoCore\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\ProvidersEsimGoCore\\ProvidersEsimGoCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
