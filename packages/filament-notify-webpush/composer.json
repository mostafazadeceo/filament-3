{
    "name": "haida/filament-notify-webpush",
    "version": "1.0.0",
    "description": "Web push notifications channel for Filament Notify.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "haida/filament-notify-core": "*",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "minishlink/web-push": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Haida\\FilamentNotify\\WebPush\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\FilamentNotify\\WebPush\\FilamentNotifyWebPushServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
