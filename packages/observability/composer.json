{
    "name": "haida/observability",
    "version": "1.0.0",
    "description": "Correlation IDs and logging context for observability.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\Observability\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\Observability\\ObservabilityServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
