{
    "name": "haida/providers-esim-go-commerce",
    "version": "1.0.0",
    "description": "Commerce integration for eSIM Go provider.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filamat/filamat-iam-suite": "dev-main",
        "haida/providers-esim-go-core": "^1.0",
        "haida/commerce-catalog": "^1.0",
        "haida/commerce-checkout": "^1.0",
        "haida/commerce-orders": "^1.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\ProvidersEsimGoCommerce\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\ProvidersEsimGoCommerce\\ProvidersEsimGoCommerceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
