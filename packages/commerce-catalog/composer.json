{
    "name": "haida/commerce-catalog",
    "version": "1.0.0",
    "description": "Commerce catalog module for Site OS.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filamat/filamat-iam-suite": "dev-main",
        "haida/site-builder-core": "^1.0",
        "haida/filament-currency-rates": "^1.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Haida\\CommerceCatalog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Haida\\CommerceCatalog\\CommerceCatalogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
