  "providers": {
    "cryptomus": {
      "features": ["invoice", "payout", "webhook", "signature", "ipAllowlist", "recurring"],
      "statusMapping": {
        "confirm_check": "confirm_check",
        "paid": "paid",
        "paid_over": "paid_over",
        "wrong_amount": "wrong_amount",
        "cancel": "cancelled",
        "cancelled": "cancelled",
        "system_fail": "failed",
        "fail": "failed",
        "refund_process": "refund_process",
        "refund_fail": "refund_failed",
        "refund_paid": "refund_paid"
      }
    },
    "coinbase": {
      "features": ["charge", "webhook", "signature", "retrySafe"],
      "statusMapping": {
        "charge:created": "unpaid",
        "charge:pending": "pending",
        "charge:confirmed": "paid",
        "charge:failed": "failed"
      }
    },
    "coinpayments": {
      "features": ["invoice", "webhook", "signature", "ipAllowlist", "reconcile", "payout_optional"],
      "statusMapping": {
        "0": "pending",
        "1": "pending",
        "2": "paid",
        "100": "paid",
        "3": "paid_over",
        "-1": "cancelled",
        "-2": "failed"
      }
    },
    "btcpay": {
      "features": ["invoice", "webhook", "paidLate/partial/over"],
      "statusMapping": {
        "New": "unpaid",
        "Processing": "pending",
        "Expired": "expired",
        "Settled": "completed",
        "Complete": "completed",
        "PaidOver": "paid_over",
        "PaidPartial": "wrong_amount",
        "PaidLate": "paid"
      }
    }
  },
  "api": {
    "base": "/api/v1/crypto",
    "endpoints": [
      "POST /invoices",
      "GET /invoices/{id}",
      "GET /invoices/{id}/status",
      "POST /invoices/{id}/refresh",
      "POST /payouts",
      "GET /payouts/{id}",
      "POST /payouts/{id}/approve",
      "POST /payouts/{id}/reject",
      "GET /payout-destinations",
      "POST /payout-destinations",
      "GET /payout-destinations/{id}",
      "PUT /payout-destinations/{id}",
      "DELETE /payout-destinations/{id}",
      "POST /webhooks/{provider}",
      "GET /rates",
      "GET /policy",
      "GET /health/providers",
      "GET /health/nodes",
      "POST /reconcile/run",
      "GET /openapi"
    ],
    "openapiPublished": true
  },
  "security": {
    "secretsEncrypted": true,
    "webhookIdempotent": true,
    "dlq": true,
    "notes": [
      "IP allowlist enforced for Cryptomus/CoinPayments",
      "HMAC/MD5 signature verification for all webhooks",
      "Payout whitelist + approval enforced"
    ]
  },
  "tenancy": {
    "scopedEverywhere": true,
    "iamPermissionsRegistered": true
  },
  "aiAuditor": {
    "enabled": true,
    "provider": "n8n-or-stub",
    "reports": ["daily", "weekly"]
  },
  "knownRisks": [
    "Cryptomus recurring is not implemented (supports.recurring=false).",
    "RPC services are available but not yet wired into invoice monitoring workflows."
  ],
  "nextBacklog": [
